{
  "name": "aethorias-keep-bot",
  "version": "1.0.0",
  "description": "A custom Discord community bot for Aethoria's Keep",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma migrate deploy && node dist/index.js",
    "start:migrate": "prisma migrate deploy && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:studio": "prisma studio",
    "commands:deploy": "tsx src/deploy-commands.ts",
    "commands:sync-permissions": "tsx src/sync-command-permissions.ts",
    "setup": "npm install && prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
