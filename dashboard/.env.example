# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Bot token (server-side only — never prefix with NEXT_PUBLIC_)
# Used by lib/permissions.ts and the guilds API to verify staff-role
# membership via GET /guilds/{id}/members/{userId}.
DISCORD_TOKEN=your_bot_token

# Session secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_random_jwt_secret_here

# Database (must match the bot's DATABASE_URL — both services share one DB)
DATABASE_URL=postgresql://user:password@host:5432/aethoriabot

# Public URL (no secrets)
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
